<?xml version="1.0"?>
<robot name="barista_robot">

    <material name="blue">
        <color rgba="0.006 0.151 0.781 1"/>
    </material>

    <material name="white">
        <color rgba="1.0 1.0 1.0 1"/>
    </material>

    <material name="black">
        <color rgba="0 0 0 1"/>
    </material>


    <link name="base_link">
        <visual>
            <geometry>
                <cylinder radius="0.178" length="0.155" />
            </geometry>
            <material name="blue" />
        </visual>

        <collision>
            <geometry>
                <cylinder radius="0.178" length="0.155" />
            </geometry>
        </collision>
    </link>

    <link name="left_caster_wheel">
        <visual>
            <origin rpy="0 1.5707 1.5707" xyz="0 0 0" />
            <geometry>
                <cylinder radius="0.0352" length="0.0206" />
            </geometry>
            <material name="black" />
        </visual>

        <collision>
            <origin rpy="0 1.5707 1.5707" xyz="0 0 0" />
            <geometry>
                <cylinder radius="0.0352" length="0.0206" />
            </geometry>
        </collision>
    </link>

    <joint name="base_link_to_left_caster_wheel_joint" type="continuous">
        <origin rpy="0 0 0" xyz="0 0.126 -0.0775" />
        <parent link="base_link" />
        <child link="left_caster_wheel" />
        <axis xyz="0 1 0" />
    </joint>

    <link name="right_caster_wheel">
        <visual>
            <origin rpy="0 1.5707 1.5707" xyz="0 0 0" />
            <geometry>
                <cylinder radius="0.0352" length="0.0206" />
            </geometry>
            <material name="black" />
        </visual>

        <collision>
            <origin rpy="0 1.5707 1.5707" xyz="0 0 0" />
            <geometry>
                <cylinder radius="0.0352" length="0.0206" />
            </geometry>
        </collision>
    </link>

    <joint name="base_link_to_right_caster_wheel_joint" type="continuous">
        <origin rpy="0 0 0" xyz="0 -0.126 -0.0775" />
        <parent link="base_link" />
        <child link="right_caster_wheel" />
        <axis xyz="0 1 0" />
    </joint>


    <link name="upper_right_rod" >
        <visual>
            <geometry>
                <cylinder radius="0.01" length="0.22" />
            </geometry>
            <material name="white" />
        </visual>

        <collision>
            <geometry>
                <cylinder radius="0.01" length="0.22" />
            </geometry>
        </collision>
    </link>

    <joint name="base_link_to_upper_right_rod_joint" type="fixed" >
        <origin rpy="0 0 0" xyz="0.07 -0.11 0.1875" />
        <parent link="base_link" />
        <child link="upper_right_rod" />
    </joint>

    <link name="lower_right_rod" >
        <visual>
            <geometry>
                <cylinder radius="0.01" length="0.22" />
            </geometry>
            <material name="white" />
        </visual>

        <collision>
            <geometry>
                <cylinder radius="0.01" length="0.22" />
            </geometry>
        </collision>
    </link>

    <joint name="base_link_to_lower_right_rod_joint" type="fixed" >
        <origin rpy="0 0 0" xyz="-0.07 -0.11 0.1875" />
        <parent link="base_link" />
        <child link="lower_right_rod" />
    </joint>

    <link name="lower_left_rod" >
        <visual>
            <geometry>
                <cylinder radius="0.01" length="0.22" />
            </geometry>
            <material name="white" />
        </visual>

        <collision>
            <geometry>
                <cylinder radius="0.01" length="0.22" />
            </geometry>
        </collision>
    </link>

    <joint name="base_link_to_lower_left_rod_joint" type="fixed" >
        <origin rpy="0 0 0" xyz="-0.07 0.11 0.1875" />
        <parent link="base_link" />
        <child link="lower_left_rod" />
    </joint>

    <link name="upper_left_rod" >
        <visual>
            <geometry>
                <cylinder radius="0.01" length="0.22" />
            </geometry>
            <material name="white" />
        </visual>

        <collision>
            <geometry>
                <cylinder radius="0.01" length="0.22" />
            </geometry>
        </collision>
    </link>

    <joint name="base_link_to_upper_left_rod_joint" type="fixed" >
        <origin rpy="0 0 0" xyz="0.07 0.11 0.1875" />
        <parent link="base_link" />
        <child link="upper_left_rod" />
    </joint>


    <link name="cup_holder_tray">
        <visual>
            <geometry>
                <cylinder radius="0.160" length="0.090" />
            </geometry>
            <material name="blue" />
        </visual>

        <collision>
            <geometry>
                <cylinder radius="0.160" length="0.090" />
            </geometry>
        </collision>
    </link>

    <joint name="base_link_to_cup_holder_tray_joint" type="fixed">
        <origin rpy="0 0 0" xyz="0 0 0.3425" />
        <parent link="base_link" />
        <child link="cup_holder_tray" />
    </joint>

    <link name="laser_scan_link">
        <visual>
            <geometry>
                <mesh filename="package://barista_robot_description/meshes/hokuyo_urg_04lx.dae" />
            </geometry>
        </visual>

        <collision>
            <geometry>
                <box size="0.02 0.02 0.05" />
            </geometry>
        </collision>
    </link>

    <joint name="base_link_to_laser_scan_link_joint" type="fixed">
        <origin rpy="0 0 0" xyz="0.089 0 0.0775"/>
        <parent link="base_link" />
        <child link="laser_scan_link" />
    </joint>

    <link name="laser_scan_frame" />

    <joint name="laser_scan_link_to_frame_joint" type="fixed" >
        <origin rpy="0 0 0" xyz="0 0 0.03" />
        <parent link="laser_scan_link" />
        <child link="laser_scan_frame" />
    </joint>

</robot>