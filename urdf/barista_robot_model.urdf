    <link name="laser_scan_link">
        <visual>
            <geometry>
                <mesh filename="package://barista_robot_description/meshes/hokuyo_urg_04lx.dae" />
            </geometry>
        </visual>

        <collision>
            <geometry>
                <box size="0.02 0.02 0.05" />
