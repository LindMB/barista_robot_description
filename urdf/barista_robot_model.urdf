    <link name="lower_left_rod" >
        <visual>
            <geometry>
                <cylinder radius="0.01" length="0.22" />
            </geometry>
            <material name="white" />
        </visual>

        <collision>
            <geometry>
                <cylinder radius="0.01" length="0.22" />
            </geometry>
        </collision>

        <inertial>
            <mass value="0.025" />
            <origin rpy="0 0 0" xyz="0 0 0" />
            <inertia ixx="0.0001014583333" ixy="0" ixz="0" iyy="0.0001014583333" iyz="0" izz="0.00000125" />
        </inertial>
    </link>

    <joint name="base_link_to_lower_left_rod_joint" type="fixed" >
        <origin rpy="0 0 0" xyz="-0.07 0.11 0.1875" />
        <parent link="base_link" />
        <child link="lower_left_rod" />
    </joint>

    <link name="upper_left_rod" >
        <visual>
            <geometry>
                <cylinder radius="0.01" length="0.22" />
            </geometry>
            <material name="white" />
        </visual>

        <collision>
            <geometry>
                <cylinder radius="0.01" length="0.22" />
            </geometry>
        </collision>

        <inertial>
            <mass value="0.025" />
            <origin rpy="0 0 0" xyz="0 0 0" />
            <inertia ixx="0.0001014583333" ixy="0" ixz="0" iyy="0.0001014583333" iyz="0" izz="0.00000125" />
        </inertial>
    </link>

    <joint name="base_link_to_upper_left_rod_joint" type="fixed" >
        <origin rpy="0 0 0" xyz="0.07 0.11 0.1875" />
        <parent link="base_link" />
        <child link="upper_left_rod" />
    </joint>


    <link name="cup_holder_tray">
        <visual>
            <geometry>
                <cylinder radius="0.160" length="0.090" />
            </geometry>
            <material name="blue" />
        </visual>

        <collision>
            <geometry>
                <cylinder radius="0.160" length="0.090" />
            </geometry>
        </collision>

        <inertial>
            <mass value="0.25" />
            <origin rpy="0 0 0" xyz="0 0 0" />
            <inertia ixx="0.00176875" ixy="0" ixz="0" iyy="0.00176875" iyz="0" izz="0.0032" />
        </inertial>
    </link>

    <joint name="base_link_to_cup_holder_tray_joint" type="fixed">
        <origin rpy="0 0 0" xyz="0 0 0.3425" />
        <parent link="base_link" />
        <child link="cup_holder_tray" />
