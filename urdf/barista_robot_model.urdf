<?xml version="1.0"?>
<robot name="barista_robot">

    <!-- Colors -->
    <material name="blue">
        <color rgba="0.006 0.151 0.781 1"/>
    </material>

    <material name="white">
        <color rgba="1.0 1.0 1.0 1"/>
    </material>

    <material name="black">
        <color rgba="0 0 0 1"/>
    </material>

    <material name="green_light">
        <color rgba="0.0 1.0 0.0 1"/>
    </material>

    <!-- Base Link -->
    <link name="base_link">
        <visual>
            <geometry>
                <cylinder radius="0.178" length="0.155" />
            </geometry>
            <material name="blue" />
        </visual>

        <collision>
            <geometry>
                <cylinder radius="0.178" length="0.155" />
            </geometry>
        </collision>

        <inertial>
            <mass value="0.5" />
            <origin rpy="0 0 0" xyz="0 0 0" />
            <inertia ixx="0.0049615416667" ixy="0" ixz="0" iyy="0.0049615416667" iyz="0" izz="0.007921" />
        </inertial>
    </link>

    <!-- Drive Wheels -->
    <link name="left_drive_wheel">
        <visual>
            <origin rpy="0 1.5707 1.5707" xyz="0 0 0" />
            <geometry>
                <cylinder radius="0.0352" length="0.0206" />
            </geometry>
            <material name="black" />
        </visual>

        <collision>
            <origin rpy="0 1.5707 1.5707" xyz="0 0 0" />
            <geometry>
                <cylinder radius="0.0352" length="0.0206" />
            </geometry>
        </collision>

        <inertial>
            <mass value="0.05" />
            <origin rpy="0 0 0" xyz="0 0 0" />
            <inertia ixx="0.0000172561667" ixy="0" ixz="0" iyy="0.0000172561667" iyz="0" izz="0.000030976" />
        </inertial>
    </link>

    <joint name="base_link_to_left_drive_wheel_joint" type="continuous">
        <origin rpy="0 0 0" xyz="0 0.126 -0.0775" />
        <parent link="base_link" />
        <child link="left_drive_wheel" />
        <axis xyz="0 1 0" />
    </joint>

    <link name="right_drive_wheel">
        <visual>
            <origin rpy="0 1.5707 1.5707" xyz="0 0 0" />
            <geometry>
                <cylinder radius="0.0352" length="0.0206" />
            </geometry>
            <material name="black" />
        </visual>

        <collision>
            <origin rpy="0 1.5707 1.5707" xyz="0 0 0" />
            <geometry>
                <cylinder radius="0.0352" length="0.0206" />
            </geometry>
        </collision>

        <inertial>
            <mass value="0.05" />
            <origin rpy="0 0 0" xyz="0 0 0" />
            <inertia ixx="0.0000172561667" ixy="0" ixz="0" iyy="0.0000172561667" iyz="0" izz="0.000030976" />
        </inertial>
    </link>

    <joint name="base_link_to_right_drive_wheel_joint" type="continuous">
        <origin rpy="0 0 0" xyz="0 -0.126 -0.0775" />
        <parent link="base_link" />
        <child link="right_drive_wheel" />
        <axis xyz="0 1 0" />
    </joint>

    <!-- Front caster wheel -->
    <link name="front_caster_wheel_roll_link" >
        <inertial>
            <mass value="0.001" />
            <origin rpy="0 0 0" xyz="0 0 0"/>
            <inertia ixx="0.000000495616" ixy="0" ixz="0" iyy="0.000000495616" iyz="0" izz="0.000000495616" />
        </inertial>
    </link>

    <joint name="front_caster_wheel_roll_joint" type="continuous" >
        <origin rpy="0 0 0" xyz="0.11 0 -0.0775" />
        <parent link="base_link" />
        <child link="front_caster_wheel_roll_link" />
        <axis xyz="1 0 0" />
    </joint>

    <link name="front_caster_wheel_pitch_link" >
        <inertial>
            <mass value="0.001" />
            <origin rpy="0 0 0" xyz="0 0 0"/>
            <inertia ixx="0.000000495616" ixy="0" ixz="0" iyy="0.000000495616" iyz="0" izz="0.000000495616" />
        </inertial>
    </link>

    <joint name="front_caster_wheel_pitch_joint" type="continuous" >
        <origin rpy="0 0 0" xyz="0 0 0" />
        <parent link="front_caster_wheel_roll_link" />
        <child link="front_caster_wheel_pitch_link" />
        <axis xyz="0 1 0" />
    </joint>

    <link name="front_caster_wheel_yaw_link" >
        <visual>
            <geometry>
                <sphere radius="0.0352" />
            </geometry>
            <material name="green_light" />
        </visual>

        <collision>
            <geometry>
                <sphere radius="0.0352" />
            </geometry>
        </collision>

        <inertial>
            <mass value="0.05" />
            <origin rpy="0 0 0" xyz="0 0 0"/>
            <inertia ixx="0.0000247808" ixy="0" ixz="0" iyy="0.0000247808" iyz="0" izz="0.0000247808" />
        </inertial>
    </link>

    <joint name="front_caster_wheel_yaw_joint" type="continuous" >
        <origin rpy="0 0 0" xyz="0 0 0" />
        <parent link="front_caster_wheel_pitch_link" />
        <child link="front_caster_wheel_yaw_link" />
        <axis xyz="0 0 1" />
    </joint>

    <!-- Back caster wheel -->
    <link name="back_caster_wheel_roll_link" >
        <inertial>
            <mass value="0.001" />
            <origin rpy="0 0 0" xyz="0 0 0"/>
            <inertia ixx="0.000000495616" ixy="0" ixz="0" iyy="0.000000495616" iyz="0" izz="0.000000495616" />
        </inertial>
    </link>

    <joint name="back_caster_wheel_roll_joint" type="continuous" >
        <origin rpy="0 0 0" xyz="-0.11 0 -0.0775" />
        <parent link="base_link" />
        <child link="back_caster_wheel_roll_link" />
        <axis xyz="1 0 0" />
    </joint>

    <link name="back_caster_wheel_pitch_link" >
        <inertial>
            <mass value="0.001" />
            <origin rpy="0 0 0" xyz="0 0 0"/>
            <inertia ixx="0.000000495616" ixy="0" ixz="0" iyy="0.000000495616" iyz="0" izz="0.000000495616" />
        </inertial>
    </link>

    <joint name="back_caster_wheel_pitch_joint" type="continuous" >
        <origin rpy="0 0 0" xyz="0 0 0" />
        <parent link="back_caster_wheel_roll_link" />
        <child link="back_caster_wheel_pitch_link" />
        <axis xyz="0 1 0" />
    </joint>

    <link name="back_caster_wheel_yaw_link" >
        <visual>
            <geometry>
                <sphere radius="0.0352" />
            </geometry>
            <material name="green_light" />
        </visual>

        <collision>
            <geometry>
                <sphere radius="0.0352" />
            </geometry>
        </collision>

        <inertial>
            <mass value="0.05" />
            <origin rpy="0 0 0" xyz="0 0 0"/>
            <inertia ixx="0.0000247808" ixy="0" ixz="0" iyy="0.0000247808" iyz="0" izz="0.0000247808" />
        </inertial>
    </link>

    <joint name="back_caster_wheel_yaw_joint" type="continuous" >
        <origin rpy="0 0 0" xyz="0 0 0" />
        <parent link="back_caster_wheel_pitch_link" />
        <child link="back_caster_wheel_yaw_link" />
        <axis xyz="0 0 1" />
    </joint>

    <!-- Standoff Rods -->
    <link name="upper_right_rod" >
        <visual>
            <geometry>
                <cylinder radius="0.01" length="0.22" />
            </geometry>
            <material name="white" />
        </visual>

        <collision>
            <geometry>
                <cylinder radius="0.01" length="0.22" />
            </geometry>
        </collision>

        <inertial>
            <mass value="0.025" />
            <origin rpy="0 0 0" xyz="0 0 0" />
            <inertia ixx="0.0001014583333" ixy="0" ixz="0" iyy="0.0001014583333" iyz="0" izz="0.00000125" />
        </inertial>
    </link>

    <joint name="base_link_to_upper_right_rod_joint" type="fixed" >
        <origin rpy="0 0 0" xyz="0.07 -0.11 0.1875" />
        <parent link="base_link" />
        <child link="upper_right_rod" />
    </joint>

    <link name="lower_right_rod" >
        <visual>
            <geometry>
                <cylinder radius="0.01" length="0.22" />
            </geometry>
            <material name="white" />
        </visual>

        <collision>
            <geometry>
                <cylinder radius="0.01" length="0.22" />
            </geometry>
        </collision>

        <inertial>
            <mass value="0.025" />
            <origin rpy="0 0 0" xyz="0 0 0" />
            <inertia ixx="0.0001014583333" ixy="0" ixz="0" iyy="0.0001014583333" iyz="0" izz="0.00000125" />
        </inertial>
    </link>

    <joint name="base_link_to_lower_right_rod_joint" type="fixed" >
        <origin rpy="0 0 0" xyz="-0.07 -0.11 0.1875" />
        <parent link="base_link" />
        <child link="lower_right_rod" />
    </joint>

    <link name="lower_left_rod" >
        <visual>
            <geometry>
                <cylinder radius="0.01" length="0.22" />
            </geometry>
            <material name="white" />
        </visual>

        <collision>
            <geometry>
                <cylinder radius="0.01" length="0.22" />
            </geometry>
        </collision>

        <inertial>
            <mass value="0.025" />
            <origin rpy="0 0 0" xyz="0 0 0" />
            <inertia ixx="0.0001014583333" ixy="0" ixz="0" iyy="0.0001014583333" iyz="0" izz="0.00000125" />
        </inertial>
    </link>

    <joint name="base_link_to_lower_left_rod_joint" type="fixed" >
        <origin rpy="0 0 0" xyz="-0.07 0.11 0.1875" />
        <parent link="base_link" />
        <child link="lower_left_rod" />
    </joint>

    <link name="upper_left_rod" >
        <visual>
            <geometry>
                <cylinder radius="0.01" length="0.22" />
            </geometry>
            <material name="white" />
        </visual>

        <collision>
            <geometry>
                <cylinder radius="0.01" length="0.22" />
            </geometry>
        </collision>

        <inertial>
            <mass value="0.025" />
            <origin rpy="0 0 0" xyz="0 0 0" />
            <inertia ixx="0.0001014583333" ixy="0" ixz="0" iyy="0.0001014583333" iyz="0" izz="0.00000125" />
        </inertial>
    </link>

    <joint name="base_link_to_upper_left_rod_joint" type="fixed" >
        <origin rpy="0 0 0" xyz="0.07 0.11 0.1875" />
        <parent link="base_link" />
        <child link="upper_left_rod" />
    </joint>

    <!-- Cup Holder Tray -->
    <link name="cup_holder_tray">
        <visual>
            <geometry>
                <cylinder radius="0.160" length="0.090" />
            </geometry>
            <material name="blue" />
        </visual>

        <collision>
            <geometry>
                <cylinder radius="0.160" length="0.090" />
            </geometry>
        </collision>

        <inertial>
            <mass value="0.25" />
            <origin rpy="0 0 0" xyz="0 0 0" />
            <inertia ixx="0.00176875" ixy="0" ixz="0" iyy="0.00176875" iyz="0" izz="0.0032" />
        </inertial>
    </link>

    <joint name="base_link_to_cup_holder_tray_joint" type="fixed">
        <origin rpy="0 0 0" xyz="0 0 0.3425" />
        <parent link="base_link" />
        <child link="cup_holder_tray" />
    </joint>

    <!-- Lidar (Model) -->
    <link name="laser_scan_link">
        <visual>
            <geometry>
                <mesh filename="package://barista_robot_description/meshes/hokuyo_urg_04lx.dae" />
            </geometry>
        </visual>

        <collision>
            <geometry>
                <box size="0.02 0.02 0.05" />
            </geometry>
        </collision>

        <inertial>
            <mass value="0.05" />
            <origin rpy="0 0 0" xyz="0 0 0" />
            <inertia ixx="0.0000110833333" ixy="0" ixz="0" iyy="0.0000110833333" iyz="0" izz="0.0000033333333" />
        </inertial>
    </link>

    <joint name="base_link_to_laser_scan_link_joint" type="fixed">
        <origin rpy="0 0 0" xyz="0.089 0 0.0775"/>
        <parent link="base_link" />
        <child link="laser_scan_link" />
    </joint>

    <link name="laser_scan_frame" />

    <joint name="laser_scan_link_to_frame_joint" type="fixed" >
        <origin rpy="0 0 0" xyz="0 0 0.05" />
        <parent link="laser_scan_link" />
        <child link="laser_scan_frame" />
    </joint>

    <!-- Lidar Sensor Plugin -->
    <gazebo reference="laser_scan_frame">
        <sensor name="sensor_ray" type="ray">
            <pose>0 0 0 0 0 0</pose>
            <ray>
                <scan>
                    <horizontal>
                        <samples>200</samples>
                        <resolution>1.0</resolution>
                        <min_angle>-3.14</min_angle>
                        <max_angle>3.14</max_angle>
                    </horizontal>
                </scan>

                <range>
                    <min>0.1</min>
                    <max>5.0</max>
                </range>
            </ray>

            <always_on>true</always_on>
            <visualize>true</visualize>
            <update_rate>100.0</update_rate>

            <plugin name="laser" filename="libgazebo_ros_ray_sensor.so">
                <ros>
                    <remapping>~/out:=scan</remapping>
                </ros>
                <output_type>sensor_msgs/LaserScan</output_type>
                <frame_name>laser_scan_frame</frame_name>
            </plugin>
        </sensor>
    </gazebo>

    <!-- Joint State Publisher Plugin -->
    <gazebo>
        <plugin name="barista_robot_joint_state" filename="libgazebo_ros_joint_state_publisher.so">
            <ros>
                <remapping>~/out:=joint_states</remapping>
            </ros>
            <update_rate>30</update_rate>

            <joint_name>base_link_to_left_drive_wheel_joint</joint_name>
            <joint_name>base_link_to_right_drive_wheel_joint</joint_name>
            
            <joint_name>front_caster_wheel_roll_joint</joint_name>
            <joint_name>front_caster_wheel_pitch_joint</joint_name>
            <joint_name>front_caster_wheel_yaw_joint</joint_name>
            
            <joint_name>back_caster_wheel_roll_joint</joint_name>
            <joint_name>back_caster_wheel_pitch_joint</joint_name>
            <joint_name>back_caster_wheel_yaw_joint</joint_name>
        </plugin>
    </gazebo>

    <!-- Differential Drive Plugin -->
    <gazebo>
        <plugin filename="libgazebo_ros_diff_drive.so" name="differential_drive_controller">
            <ros>
                <remapping>cmd_vel:=/cmd_vel</remapping>
                <remapping>odom:=/odom</remapping>
            </ros>
            
            <!-- wheel joints -->
            <left_joint>base_link_to_left_drive_wheel_joint</left_joint>
            <right_joint>base_link_to_right_drive_wheel_joint</right_joint>

            <!-- kinematics -->
            <wheel_separation>0.252</wheel_separation>
            <wheel_diameter>0.0704</wheel_diameter>

            <!-- limits -->
            <max_wheel_torque>1.0</max_wheel_torque>
            <max_wheel_acceleration>2.0</max_wheel_acceleration>

            <!-- output -->
            <publish_odom>true</publish_odom>
            <publish_odom_tf>true</publish_odom_tf>

            <odometry_frame>odom</odometry_frame>
            <robot_base_frame>base_link</robot_base_frame>
        </plugin>
    </gazebo>

</robot>