<?xml version="1.0"?>

<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

    <xacro:property name="drive_wheel_radius" value="0.0352"/>
    <xacro:property name="drive_wheel_width" value="0.0206"/>
    <xacro:property name="drive_wheel_mass" value="0.05"/>

    <xacro:property name="base_link_height" value="0.155" />

    <!-- "cylinder_inertia"
    # params="mass r l"
    # mass: Mass in Kilograms of the link
    # r: Radius of the cylinder in meters
    # l: height of the cylinder in meters-->
    <xacro:macro name="cylinder_inertia" params="mass r l" >
        <inertia ixx="${mass*(3*r*r+l*l)/12}" ixy = "0" ixz = "0"
                 iyy="${mass*(3*r*r+l*l)/12}" iyz = "0"
                 izz="${mass*(r*r)/2}" />
    </xacro:macro>

    <xacro:macro name="drive_wheel" params="drive_wheel_name origin_joint_y">
        <!-- Drive Wheel -->
        <link name="${drive_wheel_name}">
            <visual>
                <origin rpy="0 1.5707 1.5707" xyz="0 0 0" />
                <geometry>
                    <cylinder radius="${drive_wheel_radius}" length="${drive_wheel_width}" />
                </geometry>
                <material name="black" />
            </visual>

            <collision>
                <origin rpy="0 1.5707 1.5707" xyz="0 0 0" />
                <geometry>
                    <cylinder radius="${drive_wheel_radius}" length="${drive_wheel_width}" />
                </geometry>
            </collision>

            <inertial>
                <mass value="${drive_wheel_mass}" />
                <origin rpy="0 0 0" xyz="0 0 0" />
                <xacro:cylinder_inertia mass="${drive_wheel_mass}" r="${drive_wheel_radius}" l="${drive_wheel_width}" />
                <!--inertia ixx="0.0000172561667" ixy="0" ixz="0" iyy="0.0000172561667" iyz="0" izz="0.000030976" /-->
            </inertial>
        </link>

        <joint name="base_link_to_${drive_wheel_name}_joint" type="continuous">
            <origin rpy="0 0 0" xyz="0 ${origin_joint_y} ${-base_link_height/2}" />
            <parent link="base_link" />
            <child link="${drive_wheel_name}" />
            <axis xyz="0 1 0" />
        </joint>

    </xacro:macro>
</robot>