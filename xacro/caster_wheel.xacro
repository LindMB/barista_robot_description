<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

    <!--xacro:property name="caster_wheel_radius" value="0.0352" />
    <xacro:property name="caster_wheel_mass" value="0.05" />
    <xacro:property name="negligible_mass" value="0.001" /-->

    <!-- sphere_inertia"
    # params="mass r"
    # mass: Mass in Kilograms of the link
    # r: Radius of the sphere in meters -->
    <xacro:macro name="sphere_inertia" params="mass r" >
        <inertia ixx="${2*mass*r*r/5}" ixy = "0" ixz = "0"
                 iyy="${2*mass*r*r/5}" iyz = "0"
                 izz="${2*mass*r*r/5}" />
    </xacro:macro>
    
    <xacro:macro name="caster_wheel" params="prefix joint_origin_x">  
        <!-- Caster wheel -->
        <link name="${prefix}_caster_wheel_roll_link" >
            <inertial>
                <mass value="${negligible_mass}" />
                <origin rpy="0 0 0" xyz="0 0 0"/>
                <xacro:sphere_inertia mass="${negligible_mass}" r="${caster_wheel_radius}" />
                <!--inertia ixx="0.000000495616" ixy="0" ixz="0" iyy="0.000000495616" iyz="0" izz="0.000000495616" /-->
            </inertial>
        </link>

        <link name="${prefix}_caster_wheel_pitch_link" >
            <inertial>
                <mass value="${negligible_mass}" />
                <origin rpy="0 0 0" xyz="0 0 0"/>
                <xacro:sphere_inertia mass="${negligible_mass}" r="${caster_wheel_radius}" />
                <!--inertia ixx="0.000000495616" ixy="0" ixz="0" iyy="0.000000495616" iyz="0" izz="0.000000495616" /-->
            </inertial>
        </link>

        <link name="${prefix}_caster_wheel_yaw_link" >
            <visual>
                <geometry>
                    <sphere radius="${caster_wheel_radius}" />
                </geometry>
                <material name="green_dark" />
            </visual>

            <collision>
                <geometry>
                    <sphere radius="${caster_wheel_radius}" />
                </geometry>
            </collision>

            <inertial>
                <mass value="${caster_wheel_mass}" />
                <origin rpy="0 0 0" xyz="0 0 0"/>
                <xacro:sphere_inertia mass="${caster_wheel_mass}" r="${caster_wheel_radius}" />
                <!--inertia ixx="0.0000247808" ixy="0" ixz="0" iyy="0.0000247808" iyz="0" izz="0.0000247808" /-->
            </inertial>
        </link>

        <joint name="${prefix}_caster_wheel_roll_joint" type="continuous" >
            <origin rpy="0 0 0" xyz="${joint_origin_x} 0 -0.0775" />
            <parent link="base_link" />
            <child link="${prefix}_caster_wheel_roll_link" />
            <axis xyz="1 0 0" />
        </joint>

        <joint name="${prefix}_caster_wheel_pitch_joint" type="continuous" >
            <origin rpy="0 0 0" xyz="0 0 0" />
            <parent link="${prefix}_caster_wheel_roll_link" />
            <child link="${prefix}_caster_wheel_pitch_link" />
            <axis xyz="0 1 0" />
        </joint>

        <joint name="${prefix}_caster_wheel_yaw_joint" type="continuous" >
            <origin rpy="0 0 0" xyz="0 0 0" />
            <parent link="${prefix}_caster_wheel_pitch_link" />
            <child link="${prefix}_caster_wheel_yaw_link" />
            <axis xyz="0 0 1" />
        </joint>
    </xacro:macro>
</robot>