<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="barista_robot">

    <xacro:include filename="$(find barista_robot_description)/xacro/barista_robot_model.gazebo.xacro" />
    <xacro:include filename="$(find barista_robot_description)/xacro/barista_robot_model.gazebo_plugins.xacro" />
    <xacro:include filename="$(find barista_robot_description)/xacro/drive_wheel.xacro" />
    <xacro:include filename="$(find barista_robot_description)/xacro/caster_wheel.xacro" />
    <xacro:include filename="$(find barista_robot_description)/xacro/standoff_rod.xacro" />
    <xacro:include filename="$(find barista_robot_description)/xacro/cup_holder_tray.xacro" />
    <xacro:include filename="$(find barista_robot_description)/xacro/laser_scanner.xacro" />

    <xacro:property name="base_link_radius" value="0.178" />
    <xacro:property name="base_link_height" value="0.155" />
    <xacro:property name="base_link_mass" value="0.5" />

    <!-- Colors -->
    <material name="blue">
        <color rgba="0.006 0.151 0.781 1"/>
    </material>

    <material name="white">
        <color rgba="1.0 1.0 1.0 1"/>
    </material>

    <material name="black">
        <color rgba="0 0 0 1"/>
    </material>

    <material name="green_dark">
        <color rgba="0.0 0.5 0.0 1"/>
    </material>

    <!-- "cylinder_inertia"
    # params="mass r l"
    # mass: Mass in Kilograms of the link
    # r: Radius of the cylinder in meters
    # l: height of the cylinder in meters-->
    <xacro:macro name="cylinder_inertia" params="mass r l" >
        <inertia ixx="${mass*(3*r*r+l*l)/12}" ixy = "0" ixz = "0"
                 iyy="${mass*(3*r*r+l*l)/12}" iyz = "0"
                 izz="${mass*(r*r)/2}" />
    </xacro:macro>

    <!-- sphere_inertia"
    # params="mass r"
    # mass: Mass in Kilograms of the link
    # r: Radius of the sphere in meters -->
    <xacro:macro name="sphere_inertia" params="mass r" >
        <inertia ixx="${2*mass*r*r/5}" ixy = "0" ixz = "0"
                 iyy="${2*mass*r*r/5}" iyz = "0"
                 izz="${2*mass*r*r/5}" />
    </xacro:macro>

    <!-- Base Footprint -->
    <link name="base_footprint"/>

    <joint name="base_footprint_to_base_link" type="fixed">
        <origin rpy="0 0 0" xyz="0 0 0.1127" />
        <parent link="base_footprint"/>
        <child link="base_link"/>
    </joint>

    <!-- Base Link -->
    <link name="base_link">
        <visual>
            <geometry>
                <cylinder radius="${base_link_radius}" length="${base_link_height}" />
            </geometry>
            <material name="blue" />
        </visual>

        <collision>
            <geometry>
                <cylinder radius="${base_link_radius}" length="${base_link_height}" />
            </geometry>
        </collision>

        <inertial>
            <mass value="${base_link_mass}" />
            <origin rpy="0 0 0" xyz="0 0 0" />
            <xacro:cylinder_inertia mass="${base_link_mass}" r="${base_link_radius}" l="${base_link_height}" />
            <!--inertia ixx="0.0049615416667" ixy="0" ixz="0" iyy="0.0049615416667" iyz="0" izz="0.007921" /-->
        </inertial>
    </link>

    <!-- Drive Wheels -->
    <xacro:drive_wheel drive_wheel_name="left_drive_wheel" />
    <xacro:drive_wheel drive_wheel_name="right_drive_wheel" />

    <joint name="base_link_to_left_drive_wheel_joint" type="continuous">
        <origin rpy="0 0 0" xyz="0 0.126 -${base_link_height}/2" />
        <parent link="base_link" />
        <child link="left_drive_wheel" />
        <axis xyz="0 1 0" />
    </joint>

    <joint name="base_link_to_right_drive_wheel_joint" type="continuous">
        <origin rpy="0 0 0" xyz="0 -0.126 -${base_link_height}/2" />
        <parent link="base_link" />
        <child link="right_drive_wheel" />
        <axis xyz="0 1 0" />
    </joint>

    <!-- Caster Wheels + Joints-->
    <xacro:caster_wheel prefix="front" />
    <xacro:caster_wheel prefix="back" />

    <!--joint name="front_caster_wheel_roll_joint" type="continuous" >
        <origin rpy="0 0 0" xyz="0.11 0 -0.0775" />
        <parent link="base_link" />
        <child link="front_caster_wheel_roll_link" />
        <axis xyz="1 0 0" />
    </joint>

    <joint name="front_caster_wheel_pitch_joint" type="continuous" >
        <origin rpy="0 0 0" xyz="0 0 0" />
        <parent link="front_caster_wheel_roll_link" />
        <child link="front_caster_wheel_pitch_link" />
        <axis xyz="0 1 0" />
    </joint>

    <joint name="front_caster_wheel_yaw_joint" type="continuous" >
        <origin rpy="0 0 0" xyz="0 0 0" />
        <parent link="front_caster_wheel_pitch_link" />
        <child link="front_caster_wheel_yaw_link" />
        <axis xyz="0 0 1" />
    </joint>

    <joint name="back_caster_wheel_roll_joint" type="continuous" >
        <origin rpy="0 0 0" xyz="-0.11 0 -0.0775" />
        <parent link="base_link" />
        <child link="back_caster_wheel_roll_link" />
        <axis xyz="1 0 0" />
    </joint>

    <joint name="back_caster_wheel_pitch_joint" type="continuous" >
        <origin rpy="0 0 0" xyz="0 0 0" />
        <parent link="back_caster_wheel_roll_link" />
        <child link="back_caster_wheel_pitch_link" />
        <axis xyz="0 1 0" />
    </joint>

    <joint name="back_caster_wheel_yaw_joint" type="continuous" >
        <origin rpy="0 0 0" xyz="0 0 0" />
        <parent link="back_caster_wheel_pitch_link" />
        <child link="back_caster_wheel_yaw_link" />
        <axis xyz="0 0 1" />
    </joint-->

    <!-- Standoff rods -->
    <xacro:standoff_rod prefix="upper_right" />
    <xacro:standoff_rod prefix="lower_right" />
    <xacro:standoff_rod prefix="upper_left" />
    <xacro:standoff_rod prefix="lower_left" />

    <joint name="base_link_to_upper_right_rod_joint" type="fixed" >
        <origin rpy="0 0 0" xyz="0.07 -0.11 0.1875" />
        <parent link="base_link" />
        <child link="upper_right_rod" />
    </joint>

    <joint name="base_link_to_lower_right_rod_joint" type="fixed" >
        <origin rpy="0 0 0" xyz="-0.07 -0.11 0.1875" />
        <parent link="base_link" />
        <child link="lower_right_rod" />
    </joint>

    <joint name="base_link_to_lower_left_rod_joint" type="fixed" >
        <origin rpy="0 0 0" xyz="-0.07 0.11 0.1875" />
        <parent link="base_link" />
        <child link="lower_left_rod" />
    </joint>

     <joint name="base_link_to_upper_left_rod_joint" type="fixed" >
        <origin rpy="0 0 0" xyz="0.07 0.11 0.1875" />
        <parent link="base_link" />
        <child link="upper_left_rod" />
    </joint>

    <!-- Cup Holder Tray -->
    <xacro:cup_holder_tray />

    <joint name="base_link_to_cup_holder_tray_joint" type="fixed">
        <origin rpy="0 0 0" xyz="0 0 0.3425" />
        <parent link="base_link" />
        <child link="cup_holder_tray" />
    </joint>

    <xacro:arg name="include_laser" default="true"/>

    <xacro:if value="$(arg include_laser)">

        <!-- Laser scanner (Model link and Frame link) -->
        <xacro:laser_scanner />
        
        <joint name="base_link_to_laser_scan_link_joint" type="fixed">
            <origin rpy="0 0 0" xyz="0.089 0 ${base_link_height}/2"/>
            <parent link="base_link" />
            <child link="laser_scan_link" />
        </joint>

        <joint name="laser_scan_link_to_frame_joint" type="fixed" >
            <origin rpy="0 0 0" xyz="0 0 0.05" />
            <parent link="laser_scan_link" />
            <child link="laser_scan_frame" />
        </joint>

    </xacro:if>


    <!-- Gazebo physical properties and colors -->
    <xacro:gazebo_elements />

    <!-- Gazebo plugins -->
    <xacro:gazebo_plugins />

</robot>
